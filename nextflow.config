// nextflow.config
// Nextflow DSL2 configuration for the somatic + germline variant calling pipeline.
//
// PROFILES:
//   local   — runs with conda environment, laptop-safe resource caps
//   docker  — runs inside the Docker container (see docker/Dockerfile)
//
// Usage:
//   nextflow run main.nf -profile local  --module somatic
//   nextflow run main.nf -profile docker --module germline

manifest {
    name        = 'variant-calling-pipeline'
    description = 'Somatic + germline variant calling with GATK, multi-DB annotation, and agentic interpretation'
    version     = '1.0.0'
    nextflowVersion = '>=23.04.0'
}

// ── Default parameters ────────────────────────────────────────────────────────
params {
    module          = 'somatic'                          // 'somatic' | 'germline' | 'all'
    config          = 'config/pipeline_config.yml'       // path to pipeline YAML config
    outdir          = 'results'
    tracedir        = "${params.outdir}/pipeline_trace"

    // Resource defaults (overridden per profile below)
    max_memory      = '8.GB'
    max_cpus        = 4
    max_time        = '8.h'
}

// ── Process defaults ──────────────────────────────────────────────────────────
process {
    errorStrategy = 'retry'
    maxRetries    = 2

    withLabel: 'gatk' {
        cpus   = 2
        memory = { 8.GB * task.attempt }
        time   = '4.h'
    }

    withLabel: 'python' {
        cpus   = 1
        memory = '4.GB'
        time   = '1.h'
    }

    withLabel: 'low_mem' {
        cpus   = 1
        memory = '2.GB'
        time   = '30.min'
    }
}

// ── Profiles ──────────────────────────────────────────────────────────────────
profiles {

    local {
        process.executor = 'local'
        conda.enabled    = true
        conda.useMamba   = false

        process {
            withLabel: 'gatk' {
                conda = 'environment.yml'
            }
            withLabel: 'python' {
                conda = 'environment.yml'
            }
        }
    }

    docker {
        docker.enabled  = true
        docker.runOptions = '--rm -u $(id -u):$(id -g)'

        process {
            container = 'variant-pipeline:latest'
        }
    }

}

// ── Execution reports ─────────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.tracedir}/timeline.html"
}

report {
    enabled = true
    file    = "${params.tracedir}/report.html"
}

trace {
    enabled = true
    file    = "${params.tracedir}/trace.txt"
    fields  = 'task_id,name,status,exit,realtime,cpus,%cpu,memory,%mem,rss'
}
